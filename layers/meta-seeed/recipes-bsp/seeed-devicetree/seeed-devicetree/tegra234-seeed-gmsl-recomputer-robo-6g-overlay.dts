/dts-v1/;
/plugin/;

/*
CAM_FRSYNC0   L50   PH.00
CAM_FRSYNC1   K57   PR.00

CAM0_GPIO_PWDN  L49 PH.06
CAM1_GPI1_PWDN  F10 PAC.00
CAM3_GPI2_PWDN  A58 PA.03
CAM4_GPI3_PWDN  L48 PH.04

CAM0_GPIO_RST  L5 PH.03
CAM1_GPIO_RST  F9 PAC.01

CAM0_GPIO_PWR_EN  P16
CAM1_GPI1_PWR_EN P05
*/



#define CAM0_RST_L      TEGRA234_MAIN_GPIO(H, 3)
#define CAM0_PWDN   TEGRA234_MAIN_GPIO(H, 6)

#define CAM0_VDD    14

#define CAM1_RST_L      TEGRA234_MAIN_GPIO(AC, 1)
#define CAM1_PWDN   TEGRA234_MAIN_GPIO(AC, 0)

#define CAM1_VDD    5

#define SYNC_OUT        TEGRA234_MAIN_GPIO(R, 0)

#define CAM2_PWDN   TEGRA234_MAIN_GPIO(A, 3)
#define CAM3_PWDN   TEGRA234_MAIN_GPIO(H, 4)

#include <dt-bindings/clock/tegra234-clock.h>
#include <dt-bindings/gpio/tegra234-gpio.h>
#include <dt-bindings/tegra234-p3737-0000+p3701-0000.h>


/ {
        overlay-name = "Seeed GMSL 6g for recomputer-robo";
        jetson-header-name = "Jetson AGX CSI Connector";
        compatible = JETSON_COMPATIBLE;

        fragment@0 {
                target-path = "/";
                __overlay__ {
                        obc_cam_sync {
                                compatible = "orbbec,obc_cam_sync";
                                ranges = <0x0 0x0 0xc6a0000 0x10000>;
                                reg = <0x0 0xc6a0000 0x0 0x18>;
                                #address-cells = <1>;
                                #size-cells = <1>;
                                status = "okay";
                                //sync-in-gpios = <&gpio_aon SYNC_IN GPIO_ACTIVE_HIGH>;
                                sync-out-gpios = <&gpio SYNC_OUT GPIO_ACTIVE_HIGH>;  //Use hrtimer to generate trigger signals
                                // pwms = <&sync_pwm 0 33333333>; //Use PWM to generate trigger signals, Default PWM mode, if use hrtimer comment out this line
                                /* EDGE_OUT #3 */
                                generator@500 {
                                        reg = <0x500 0x80>;
                                        freq_hz = <30>;
                                        duty_cycle = <10>;
                                        offset_ms = <0>;
                                        status = "disable";
                                };
                        };

                        cam0_vdd {
                                compatible = "regulator-fixed";
                                regulator-name = "cam0-vdd";
                                gpio = <&gpio_xten CAM0_VDD GPIO_ACTIVE_HIGH>;
                                enable-active-high;
                                regulator-boot-on;
                                regulator-always-on;
                        };

                        cam1_vdd {
                                compatible = "regulator-fixed";
                                regulator-name = "cam1-vdd";
                                gpio = <&gpio_xten CAM1_VDD GPIO_ACTIVE_HIGH>;
                                enable-active-high;
                                regulator-boot-on;
                                regulator-always-on;
                        };

                        bus@0{
                                /* GPIO configuration */
                                gpio@2200000 {
                                        camera-control-output-high1 {
                                                gpio-hog;
                                                output-high;
                                                gpios = <CAM0_RST_L 0 CAM1_RST_L 0 CAM0_PWDN 0 CAM1_PWDN 0 CAM2_PWDN 0 CAM3_PWDN 0>;
                                                label = "cam0-rst", "cam1-rst", "cam0-pwdn", "cam1-pwdn", "cam2-pwdn", "cam3-pwdn";
                                        };
                                };

                                host1x@13e00000 {
                                        nvcsi@15a00000 {
                                                num-channels = <0x08>;

                                                #address-cells = <1>;
                                                #size-cells = <0>;

                                                channel@0 {
                                                        reg = <0x00>;

                                                        ports {
                                                                #address-cells = <1>;
                                                                #size-cells = <0>;

                                                                port@0 {
                                                                        reg = <0>;

                                                                        csi_0_in: endpoint {
                                                                                remote-endpoint = <&des_0_ch_0_out>;
                                                                                port-index = <0x02>;
                                                                                bus-width = <0x04>;
                                                                        };
                                                                };

                                                                port@1 {
                                                                        reg = <1>;

                                                                        csi_0_out: endpoint {
                                                                                remote-endpoint = <&vi_in0>;
                                                                        };
                                                                };
                                                        };
                                                };


                                                channel@1 {
                                                        reg = <0x01>;

                                                        ports {
                                                                #address-cells = <1>;
                                                                #size-cells = <0>;

                                                                port@0 {
                                                                        reg = <0>;

                                                                        csi_1_in: endpoint {
                                                                                remote-endpoint = <&des_0_ch_1_out>;
                                                                                port-index = <0x02>;
                                                                                bus-width = <0x04>;
                                                                        };
                                                                };

                                                                port@1 {
                                                                        reg = <1>;

                                                                        csi_1_out: endpoint {
                                                                                remote-endpoint = <&vi_in1>;
                                                                        };
                                                                };
                                                        };
                                                };

                                                channel@2 {
                                                        reg = <0x02>;

                                                        ports {
                                                                #address-cells = <1>;
                                                                #size-cells = <0>;

                                                                port@0 {
                                                                        reg = <0>;

                                                                        csi_2_in: endpoint {
                                                                                remote-endpoint = <&des_0_ch_2_out>;
                                                                                port-index = <0x02>;
                                                                                bus-width = <0x04>;
                                                                        };
                                                                };

                                                                port@1 {
                                                                        reg = <1>;

                                                                        csi_2_out: endpoint {
                                                                                remote-endpoint = <&vi_in2>;
                                                                        };
                                                                };
                                                        };
                                                };

                                                channel@3 {
                                                        reg = <0x03>;

                                                        ports {
                                                                #address-cells = <1>;
                                                                #size-cells = <0>;

                                                                port@0 {
                                                                        reg = <0>;

                                                                        csi_3_in: endpoint {
                                                                                remote-endpoint = <&des_0_ch_3_out>;
                                                                                port-index = <0x02>;
                                                                                bus-width = <0x04>;
                                                                        };
                                                                };

                                                                port@1 {
                                                                        reg = <1>;

                                                                        csi_3_out: endpoint {
                                                                                remote-endpoint = <&vi_in3>;
                                                                        };
                                                                };
                                                        };
                                                };


                                                channel@4 {
                                                        reg = <0x04>;

                                                        ports {
                                                                #address-cells = <1>;
                                                                #size-cells = <0>;

                                                                port@0 {
                                                                        reg = <0>;

                                                                        csi_4_in: endpoint {
                                                                                remote-endpoint = <&des_1_ch_0_out>;
                                                                                port-index = <0x06>;
                                                                                bus-width = <0x04>;
                                                                        };
                                                                };

                                                                port@1 {
                                                                        reg = <1>;

                                                                        csi_4_out: endpoint {
                                                                                remote-endpoint = <&vi_in4>;
                                                                        };
                                                                };
                                                        };
                                                };


                                                channel@5 {
                                                        reg = <0x05>;

                                                        ports {
                                                                #address-cells = <1>;
                                                                #size-cells = <0>;

                                                                port@0 {
                                                                        reg = <0>;

                                                                        csi_5_in: endpoint {
                                                                                remote-endpoint = <&des_1_ch_1_out>;
                                                                                port-index = <0x06>;
                                                                                bus-width = <0x04>;
                                                                        };
                                                                };

                                                                port@1 {
                                                                        reg = <1>;

                                                                        csi_5_out: endpoint {
                                                                                remote-endpoint = <&vi_in5>;
                                                                        };
                                                                };
                                                        };
                                                };

                                                channel@6 {
                                                        reg = <0x06>;

                                                        ports {
                                                                #address-cells = <1>;
                                                                #size-cells = <0>;

                                                                port@0 {
                                                                        reg = <0>;

                                                                        csi_6_in: endpoint {
                                                                                remote-endpoint = <&des_1_ch_2_out>;
                                                                                port-index = <0x06>;
                                                                                bus-width = <0x04>;
                                                                        };
                                                                };

                                                                port@1 {
                                                                        reg = <1>;

                                                                        csi_6_out: endpoint {
                                                                                remote-endpoint = <&vi_in6>;
                                                                        };
                                                                };
                                                        };
                                                };

                                                channel@7 {
                                                        reg = <0x07>;

                                                        ports {
                                                                #address-cells = <1>;
                                                                #size-cells = <0>;

                                                                port@0 {
                                                                        reg = <0>;

                                                                        csi_7_in: endpoint {
                                                                                remote-endpoint = <&des_1_ch_3_out>;
                                                                                port-index = <0x06>;
                                                                                bus-width = <0x04>;
                                                                        };
                                                                };

                                                                port@1 {
                                                                        reg = <1>;

                                                                        csi_7_out: endpoint {
                                                                                remote-endpoint = <&vi_in7>;
                                                                        };
                                                                };
                                                        };
                                                };



                                        };
                                };



                                i2c@3190000{
                                        des0: gmsl-deserializer0@0x29{
                                                #address-cells = <1>;
                                                #size-cells = <0>;
                                                i2c-alias-pool = <0x41 0x42 0x43 0x44>;
                                                compatible = "maxim,max96712";
                                                reset-gpios = <&gpio CAM0_RST_L GPIO_ACTIVE_HIGH>;
                                                reg = <0x29>;
                                                status = "okay";
                                                maxim,speed-mode = <0x01>;// 6G
                                                fsync_mfp_in = <2>;
                                                phy@1 {
                                                        reg = <0x01>;
                                                        maxim,alt-mem-map8;
                                                };

                                                pipe@0 {
                                                        reg = <0x00>;
                                                        maxim,phy-id = <0x01>;
                                                        maxim,stream-id = <0x00>;
                                                        maxim,link-id = <0x00>;
                                                };

                                                pipe@1 {
                                                        reg = <0x01>;
                                                        maxim,phy-id = <0x01>;
                                                        maxim,stream-id = <0x01>;
                                                        maxim,link-id = <0x01>;
                                                };

                                                pipe@2 {
                                                        reg = <0x02>;
                                                        maxim,phy-id = <0x01>;
                                                        maxim,stream-id = <0x02>;
                                                        maxim,link-id = <0x02>;
                                                };

                                                pipe@3 {
                                                        reg = <0x03>;
                                                        maxim,phy-id = <0x01>;
                                                        maxim,stream-id = <0x03>;
                                                        maxim,link-id = <0x03>;
                                                };

                                                channel@0{
                                                        reg = <0x00>;
                                                        label = "des_0_ch_0";
                                                        maxim,phy-id = <0x01>;
                                                        ports{
                                                                #address-cells = <1>;
                                                                #size-cells = <0>;
                                                                port@0{
                                                                        reg = <0>;
                                                                        des_0_ch_0_out: endpoint {
                                                                                remote-endpoint = <&csi_0_in>;
                                                                                clock-lanes = <0x00>;
                                                                                data-lanes = <1 2 3 4>;
                                                                                link-frequencies = <0x00 0x4a817c80>;
                                                                        };
                                                                };

                                                                port@1 {
                                                                        reg = <1>;

                                                                        des_0_ch_0_in: endpoint {
                                                                                remote-endpoint = <&ser_0_ch_0_out>;
                                                                        };
                                                                };

                                                        };

                                                };


                                                channel@1{
                                                        reg = <0x01>;
                                                        label = "des_0_ch_1";
                                                        maxim,phy-id = <0x01>;
                                                        ports{
                                                                #address-cells = <1>;
                                                                #size-cells = <0>;
                                                                port@0{
                                                                        reg = <0>;

                                                                        des_0_ch_1_out: endpoint {
                                                                                remote-endpoint = <&csi_1_in>;
                                                                                clock-lanes = <0x00>;
                                                                                data-lanes = <1 2 3 4>;
                                                                                link-frequencies = <0x00 0x4a817c80>;
                                                                        };
                                                                };

                                                                port@1 {
                                                                        reg = <1>;

                                                                        des_0_ch_1_in: endpoint {
                                                                                remote-endpoint = <&ser_1_ch_1_out>;
                                                                        };
                                                                };

                                                        };

                                                };

                                                channel@2{
                                                        reg = <0x02>;
                                                        label = "des_0_ch_2";
                                                        maxim,phy-id = <0x01>;
                                                        ports{
                                                                #address-cells = <1>;
                                                                #size-cells = <0>;
                                                                port@0{
                                                                        reg = <0>;

                                                                        des_0_ch_2_out: endpoint {
                                                                                remote-endpoint = <&csi_2_in>;
                                                                                clock-lanes = <0x00>;
                                                                                data-lanes = <1 2 3 4>;
                                                                                link-frequencies = <0x00 0x4a817c80>;
                                                                        };
                                                                };

                                                                port@1 {
                                                                        reg = <1>;

                                                                        des_0_ch_2_in: endpoint {
                                                                                remote-endpoint = <&ser_2_ch_2_out>;
                                                                        };
                                                                };

                                                        };

                                                };

                                                channel@3{
                                                        reg = <0x03>;
                                                        label = "des_0_ch_3";
                                                        maxim,phy-id = <0x01>;

                                                        ports{
                                                                #address-cells = <1>;
                                                                #size-cells = <0>;

                                                                port@0{
                                                                        reg = <0>;

                                                                        des_0_ch_3_out: endpoint {
                                                                                remote-endpoint = <&csi_3_in>;
                                                                                clock-lanes = <0x00>;
                                                                                data-lanes = <1 2 3 4>;
                                                                                link-frequencies = <0x00 0x4a817c80>;
                                                                        };
                                                                };

                                                                port@1 {
                                                                        reg = <1>;
                                                                        des_0_ch_3_in: endpoint {
                                                                                remote-endpoint = <&ser_3_ch_3_out>;
                                                                        };
                                                                };

                                                        };

                                                };

                                                i2c-atr {
                                                        #address-cells = <1>;
                                                        #size-cells = <0>;
                                                        des_i2c_0: i2c@0 {
                                                                #address-cells = <1>;
                                                                #size-cells = <0>;
                                                                reg = <0>;
                                                                ser_0: gmsl-serializer@0x40 {
                                                                        #address-cells = <1>;
                                                                        #size-cells = <0>;
                                                                        compatible = "maxim,max9295a";
                                                                        reg = <0x40>;
                                                                        gpio-controller;
                                                                        #gpio-cells = <2>;
                                                                        gpio-ranges = <&ser_0 0 0 11>;
                                                                        i2c-alias-pool = <0x08>;

                                                                        i2c-atr {
                                                                                #address-cells = <1>;
                                                                                #size-cells = <0>;

                                                                                ser_0_i2c_0: i2c@0 {
                                                                                        #address-cells = <1>;
                                                                                        #size-cells = <0>;
                                                                                        reg = <0>;


                                                                                        cam_0: ox03a@0x1a {
                                                                                                #address-cells = <1>;
                                                                                                #size-cells = <0>;

                                                                                                compatible = "nv,nv-cam";
                                                                                                reg = <0x1a>;

                                                                                                must_need_cmd = <0x00>;

                                                                                                label = "cam_0";

                                                                                                // pinctrl-0 = <&CAM_PWDN_LABEL &CAM_FSYNC_LABEL>;
                                                                                                // pinctrl-names = "default";

                                                                                                pwdn-gpios = <&ser_0 0 GPIO_ACTIVE_HIGH>;
                                                                                                nv,pwdn-sleep-us = <500000>;

                                                                                                reset-gpios = <&ser_0 7 GPIO_ACTIVE_HIGH>;

                                                                                                physical_w = "15.0";
                                                                                                physical_h = "12.5";

                                                                                                sensor_model = "isx031";

                                                                                                use_sensor_mode_id = "true";

                                                                                                nv,reg-bits = <16>;
                                                                                                nv,val-bits = <8>;

                                                                                                nv,chip-id-regs = <0x7e8a 0x7e8b>;
                                                                                                nv,chip-id-masks = <0xff 0x0f>;
                                                                                                nv,chip-id-vals = <0x31 0x0>;

                                                                                                nv,wait-ms-cmd = <0x32>;

                                                                                                nv,mode-common-cmd = <
                                                                                                0x8a01 0x00 /* Stream off */
                                                                                                0x8af0 0x01
                                                                                                0xbf14 0x01 /* SW reset */
                                                                                                >;

                                                                                                nv,start-stream-cmd = <
                                                                                                0x8a01 0x80 /* Stream on */
                                                                                                >;

                                                                                                nv,stop-stream-cmd = <0x8a01 0x00>;


                                                                                                mode0 {/*ox03a*/
                                                                                                        nv,mode-cmd = <0>;
                                                                                                        mclk_khz = "24000";
                                                                                                        set_mode_delay_ms = "5000";
                                                                                                        num_lanes = "4";
                                                                                                        tegra_sinterface = "serial_c";
                                                                                                        vc_id = "0";
                                                                                                        phy_mode = "DPHY";
                                                                                                        discontinuous_clk = "no";
                                                                                                        dpcm_enable = "false";
                                                                                                        cil_settletime = "0";
                                                                                                        lane_polarity = "0";

                                                                                                        active_w = "1920";
                                                                                                        active_h = "1536";

                                                                                                        readout_orientation = "0";
                                                                                                        csi_pixel_bit_depth = "16";
                                                                                                        dynamic_pixel_bit_depth = "16";
                                                                                                        mode_type = "yuv";
                                                                                                        pixel_phase = "yuyv";
                                                                                                        line_length = "2200";
                                                                                                        inherent_gain = "1";
                                                                                                        pix_clk_hz = "200000000";
                                                                                                        serdes_link_freq = "1250000000";


                                                                                                        gain_factor = "1000";
                                                                                                        min_gain_val = "1"; /* 1.00x */
                                                                                                        max_gain_val = "30000"; /* 15.5x (16 - 1/16) */
                                                                                                        step_gain_val = "300";
                                                                                                        default_gain = "16"; /* 1.00x */

                                                                                                        min_hdr_ratio = "1";
                                                                                                        max_hdr_ratio = "1";

                                                                                                        framerate_factor = "1000000";
                                                                                                        min_framerate = "30000000"; /* 30.0 fps */
                                                                                                        max_framerate = "30000000"; /* 30.0 fps */
                                                                                                        step_framerate = "1";
                                                                                                        default_framerate = "30000000"; /* 30.0 fps */

                                                                                                        exposure_factor = "1000000";
                                                                                                        min_exp_time = "59"; /* us */
                                                                                                        max_exp_time = "33333"; /* us */
                                                                                                        step_exp_time = "1";
                                                                                                        default_exp_time = "33333"; /* us */

                                                                                                        embedded_metadata_height = "0";
                                                                                                };

                                                                                                mode1 {/*imx390 || ar0233c */
                                                                                                        nv,mode-cmd = <0>;
                                                                                                        mclk_khz = "24000";
                                                                                                        set_mode_delay_ms = "5000";
                                                                                                        num_lanes = "4";
                                                                                                        tegra_sinterface = "serial_c";
                                                                                                        vc_id = "0";
                                                                                                        phy_mode = "DPHY";
                                                                                                        discontinuous_clk = "no";
                                                                                                        dpcm_enable = "false";
                                                                                                        cil_settletime = "0";
                                                                                                        lane_polarity = "0";

                                                                                                        active_w = "1920";
                                                                                                        active_h = "1080";

                                                                                                        readout_orientation = "0";
                                                                                                        csi_pixel_bit_depth = "16";
                                                                                                        dynamic_pixel_bit_depth = "16";
                                                                                                        mode_type = "yuv";
                                                                                                        pixel_phase = "yuyv";
                                                                                                        line_length = "2200";
                                                                                                        inherent_gain = "1";
                                                                                                        pix_clk_hz = "200000000";
                                                                                                        serdes_link_freq = "1250000000";
                                                                                                        gain_factor = "1000";
                                                                                                        min_gain_val = "1"; /* 1.00x */
                                                                                                        max_gain_val = "30000"; /* 15.5x (16 - 1/16) */
                                                                                                        step_gain_val = "300";
                                                                                                        default_gain = "16"; /* 1.00x */

                                                                                                        min_hdr_ratio = "1";
                                                                                                        max_hdr_ratio = "1";

                                                                                                        framerate_factor = "1000000";
                                                                                                        min_framerate = "30000000"; /* 30.0 fps */
                                                                                                        max_framerate = "30000000"; /* 30.0 fps */
                                                                                                        step_framerate = "1";
                                                                                                        default_framerate = "30000000"; /* 30.0 fps */

                                                                                                        exposure_factor = "1000000";
                                                                                                        min_exp_time = "59"; /* us */
                                                                                                        max_exp_time = "33333"; /* us */
                                                                                                        step_exp_time = "1";
                                                                                                        default_exp_time = "33333"; /* us */

                                                                                                        embedded_metadata_height = "0";
                                                                                                };
                                                                                                mode2 {/* ar0820c */
                                                                                                        nv,mode-cmd = <0>;
                                                                                                        mclk_khz = "24000";
                                                                                                        set_mode_delay_ms = "5000";
                                                                                                        num_lanes = "4";
                                                                                                        tegra_sinterface = "serial_c";
                                                                                                        vc_id = "0";
                                                                                                        phy_mode = "DPHY";
                                                                                                        discontinuous_clk = "no";
                                                                                                        dpcm_enable = "false";
                                                                                                        cil_settletime = "0";
                                                                                                        lane_polarity = "0";

                                                                                                        active_w = "3840";
                                                                                                        active_h = "2160";

                                                                                                        readout_orientation = "0";
                                                                                                        csi_pixel_bit_depth = "16";
                                                                                                        dynamic_pixel_bit_depth = "16";
                                                                                                        mode_type = "yuv";
                                                                                                        pixel_phase = "yuyv";
                                                                                                        line_length = "2200";
                                                                                                        inherent_gain = "1";
                                                                                                        pix_clk_hz = "200000000";

                                                                                                        serdes_link_freq = "1250000000";


                                                                                                        gain_factor = "1000";
                                                                                                        min_gain_val = "1"; /* 1.00x */
                                                                                                        max_gain_val = "30000"; /* 15.5x (16 - 1/16) */
                                                                                                        step_gain_val = "300";
                                                                                                        default_gain = "16"; /* 1.00x */

                                                                                                        min_hdr_ratio = "1";
                                                                                                        max_hdr_ratio = "1";

                                                                                                        framerate_factor = "1000000";
                                                                                                        min_framerate = "30000000"; /* 30.0 fps */
                                                                                                        max_framerate = "30000000"; /* 30.0 fps */
                                                                                                        step_framerate = "1";
                                                                                                        default_framerate = "30000000"; /* 30.0 fps */

                                                                                                        exposure_factor = "1000000";
                                                                                                        min_exp_time = "59"; /* us */
                                                                                                        max_exp_time = "33333"; /* us */
                                                                                                        step_exp_time = "1";
                                                                                                        default_exp_time = "33333"; /* us */

                                                                                                        embedded_metadata_height = "0";
                                                                                                };

                                                                                                ports {
                                                                                                        #address-cells = <1>;
                                                                                                        #size-cells = <0>;
                                                                                                        port@0 {
                                                                                                                reg = <0>;

                                                                                                                cam_0_out: endpoint {
                                                                                                                        port-index = <0x02>;
                                                                                                                        bus-width = <0x04>;
                                                                                                                        remote-endpoint = <&ser_0_ch_0_in>;
                                                                                                                        data-lanes = <1 2 3 4>;
                                                                                                                        clock-lanes = <0>;
                                                                                                                };
                                                                                                        };
                                                                                                };
                                                                                        };

                                                                                };
                                                                        };

                                                                        pipe@0 {
                                                                                reg = <0>;
                                                                                maxim,stream-id = <0x00>;
                                                                                maxim,dbl8;
                                                                                maxim,soft-bpp = <0x10>;
                                                                        };

                                                                        channel@0 {
                                                                                reg = <0>;

                                                                                label = "ser_0_ch_0";

                                                                                ports {
                                                                                        #address-cells = <1>;
                                                                                        #size-cells = <0>;

                                                                                        port@0 {
