                                                                                                                        remote-endpoint = <&ser_3_ch_3_in>;
                                                                                                                        data-lanes = <1 2 3 4>;
                                                                                                                        clock-lanes = <0>;
                                                                                                                };
                                                                                                        };
                                                                                                };
                                                                                        };

                                                                                };
                                                                        };

